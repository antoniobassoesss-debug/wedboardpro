{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@skills/*": ["./skills/*"]
    }
  },
  "include": [
    "shared/**/*.ts",
    "tier1-strategy/**/*.ts",
    "tier2-execution/**/*.ts",
    "tier3-quality/**/*.ts",
    "orchestration/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
